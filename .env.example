# ============================================
# 🎥 FocoCero - MS-MULTIMEDIA
# ============================================
# Copia este archivo a .env y completa tus variables

PORT=3005
NODE_ENV=development

# --- PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fococero_multimedia
DB_HOST=localhost
DB_PORT=5432

# --- Firebase Admin SDK (Service Account) ---
# Crea una cuenta de servicio en Firebase Console > Configuración del proyecto
# > Cuentas de servicio > Generar nueva clave privada
# Usa los valores de ese archivo JSON aquí
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=tu-project-id.appspot.com

# --- API Gateway ---
GATEWAY_URL=http://localhost:3000
INTERNAL_SECRET_TOKEN=dev-internal-token
EUREKA_HOST=localhost
