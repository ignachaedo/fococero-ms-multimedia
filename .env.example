# ==========================================
# 🖼️ MS-MULTIMEDIA - Variables de Entorno
# ==========================================
# Copia este archivo a .env y personaliza

# Puerto del servicio
PORT=3005

# Node environment
NODE_ENV=development

# Base de datos PostgreSQL (Docker)
DB_USER=fococero_admin
DB_PASSWORD=change-me-db-password
DB_HOST=db-fococero
DB_PORT=5432
DB_NAME=multimedia_db

# Base de datos PostgreSQL (Local)
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=5433

# Eureka Service Discovery
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_CLIENT_REGISTERWITHEUREKA=true
EUREKA_CLIENT_FETCHREGISTRY=true
EUREKA_INSTANCE_PORT=3005

# Seguridad interna
INTERNAL_SECRET_TOKEN=change-me-internal-token
GATEWAY_URL=http://api-gateway:3000

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
